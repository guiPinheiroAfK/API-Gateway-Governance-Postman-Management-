PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=orquestra-super-secret-key-change-in-production
JWT_EXPIRES_IN=1h

# Redis (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Microservices
USERS_SERVICE_URL=http://localhost:8081
PRODUCTS_SERVICE_URL=http://localhost:8082
ORDERS_SERVICE_URL=http://localhost:8083
